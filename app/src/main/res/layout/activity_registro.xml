<?xml version="1.0" encoding="utf-8"?>

<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="top|center_horizontal"
    android:padding="8dp"
    android:paddingTop="32dp"
    android:background="@drawable/fondo"
    >

    <ImageView
        android:id="@+id/imgLogo"
        android:layout_width="333dp"
        android:layout_height="76dp"
        android:adjustViewBounds="true"
        android:src="@drawable/titulo2" />

    <LinearLayout

        android:layout_width="360dp"
        android:layout_height="469dp"
        android:background="@drawable/nube"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingLeft="32dp"
        android:paddingRight="32dp"
        android:paddingTop="10dp"
        android:paddingBottom="20dp"
        >


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Ingresa tus datos "
            android:textAlignment="center"
            android:textColor="#000"
            android:textStyle="bold"
            android:textSize="25sp" />

        <EditText
            android:id="@+id/etNombre"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Nombre"
            android:textColor="#000000"
            android:layout_marginTop="10dp"
            android:textSize="16sp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/etApellidoPaterno"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Apellido Paterno"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/etApellidoMaterno"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Apellido Materno"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/etUsuario"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Usuario"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"/>

        <EditText
            android:id="@+id/etEmail"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Correo"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"
            android:inputType="textEmailAddress"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/contorno"
            android:backgroundTint="@null"
            android:hint="Contraseña"
            android:textColor="#000000"
            android:textSize="16sp"
            android:gravity="center"
            android:inputType="textPassword"/>

        <Button
            android:id="@+id/btnRegister"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Crear Cuenta"
            android:fontFamily="@font/saiyan_sans"
            android:textColor="#FFFFFF"
            android:textSize="20sp"
            android:backgroundTint="#1565C0"/>

        <TextView
            android:id="@+id/tvRegresar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="¿Ya tienes cuenta?"
            android:textColor="#FFD54F"
            android:textStyle="bold" />

    </LinearLayout>

</LinearLayout>